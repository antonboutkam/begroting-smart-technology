#!/usr/bin/env php
<?php

declare(strict_types=1);

use Roc\SmartTech\Begroting\Classes\Commands\UsersCommand;
use Roc\SmartTech\Begroting\Classes\Repositories\UserRepository;
use Symfony\Component\Console\Application;

require dirname(__DIR__) . '/vendor/autoload.php';

$config = require dirname(__DIR__) . '/config/bootstrap.php';

$application = new Application('Smart Technology Begroting');
$application->add(new UsersCommand(new UserRepository($config['db'])));
$application->run();
