{% extends 'Shared/views/layout.twig' %}

{% block content %}
    <section class="page-header">
        <div>
            <h2>Leveranciers</h2>
            <p class="muted">Beheer leveranciers, verzendkosten en documentatie.</p>
        </div>
    </section>

    <div class="two-column">
        <section class="panel">
            <h3>Nieuwe leverancier</h3>
            <form method="post" class="form-grid">
                <label><span>Naam</span><input type="text" name="name" required></label>
                <label><span>BTW tarief</span><input type="number" step="0.01" name="vat_rate" value="21"></label>
                <label><span>Verzendkosten excl.</span><input type="number" step="0.01" name="shipping_excl"></label>
                <label><span>Verzendkosten incl.</span><input type="number" step="0.01" name="shipping_incl"></label>
                <label class="full"><span>Omschrijving</span><textarea name="description" rows="4"></textarea></label>
                <button type="submit">Leverancier aanmaken</button>
            </form>
        </section>

        <section class="panel">
            <h3>Lijst</h3>
            <table>
                <thead>
                    <tr>
                        <th>Naam</th>
                        <th>BTW</th>
                        <th>Verzendkosten excl.</th>
                        <th>Verzendkosten incl.</th>
                    </tr>
                </thead>
                <tbody>
                    {% for supplier in suppliers %}
                        <tr>
                            <td><a href="/suppliers/{{ supplier.id }}">{{ supplier.name }}</a></td>
                            <td>{{ supplier.vat_rate }}%</td>
                            <td>{{ supplier.shipping_excl ?: '-' }}</td>
                            <td>{{ supplier.shipping_incl ?: '-' }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4">Nog geen leveranciers aanwezig.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>
{% endblock %}
