{% macro render(nodes, selected_ids) %}
    <ul class="tree">
        {% for node in nodes %}
            <li>
                <label>
                    <input type="checkbox" name="categories[]" value="{{ node.id }}" {% if node.id in selected_ids %}checked{% endif %}>
                    {{ node.name }}
                </label>
                {% if node.children %}
                    {{ _self.render(node.children, selected_ids) }}
                {% endif %}
            </li>
        {% endfor %}
    </ul>
{% endmacro %}
